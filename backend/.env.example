APP_NAME="AI Notes App"
APP_ENV=local
APP_KEY=base64:7B5aH1v8cO9zL4wR6eK3mS1dY8xT5pU2uV0bN1qX3yM=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=ai_notes_app
DB_USERNAME=root
DB_PASSWORD=root

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# Laravel 11 uses CACHE_STORE instead of CACHE_DRIVER
CACHE_STORE=redis
CACHE_DRIVER=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

AI_PROVIDER=gemini

OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL_SUMMARY=gpt-4o-mini
OPENAI_MODEL_EMBEDDING=text-embedding-3-small

GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL_SUMMARY=gemini-2.5-flash
GEMINI_MODEL_EMBEDDING=gemini-embedding-001
